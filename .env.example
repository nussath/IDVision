# Copy this file to .env and fill in real values. .env is gitignored.

# FastAPI session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string

# First-admin bootstrap. Used only if the users table has no admin.
# Leave blank to skip auto-creation (you'll need to create an admin manually).
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# Path to the SQLite database file.
DB_PATH=surveillance.db

# Camera index for cv2.VideoCapture. 0 = default built-in webcam.
CAMERA_INDEX=0

# Session lifetime in minutes. Users are logged out after this much idle time.
SESSION_MAX_AGE_MINUTES=60

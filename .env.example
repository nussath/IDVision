# Copy this file to .env and fill in real values. .env is gitignored.

# FastAPI session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string

# First-admin bootstrap. Used only if the users table has no admin.
# Leave blank to skip auto-creation (you'll need to create an admin manually).
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# Path to the SQLite database file.
DB_PATH=surveillance.db

# Camera index for cv2.VideoCapture. 0 = default built-in webcam.
CAMERA_INDEX=0

# Human-readable label for this camera, attached to every alert and email.
CAMERA_LOCATION=Main Entrance — Block A

# Where to write JPEG snapshots of confirmed matches.
SNAPSHOT_DIR=alerts_snapshots

# Session lifetime in minutes. Users are logged out after this much idle time.
SESSION_MAX_AGE_MINUTES=60

# Max size (MB) per uploaded photo in the enrollment form.
MAX_UPLOAD_MB=5

# Recognition tuning. Lower threshold = stricter match. Streak filter requires
# the same person to appear in >= REQUIRED of the last WINDOW predictions before
# an alert fires (suppresses flickery false positives).
LBPH_CONFIDENCE_THRESHOLD=70
RECOGNITION_STREAK_WINDOW=5
RECOGNITION_STREAK_REQUIRED=3
ALERT_COOLDOWN_SECONDS=30

# Email alerts (Gmail SMTP example).
# EMAIL_ENABLED=true toggles delivery. Without it, alerts only go to the DB.
# For Gmail, use a 16-char App Password (not your normal password):
#   https://myaccount.google.com/apppasswords
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
